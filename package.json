{
  "name": "@maplibre-three-aabb/source",
  "version": "0.0.0",
  "main": "dist/electron/main.js",
  "license": "MIT",
  "scripts": {
    "start": "nx serve",
    "build": "nx build",
    "test": "nx test",
    "word:md": "node scripts/word-to-markdown.cjs",
    "dev:web": "nx serve map-aabb",
    "build:web": "nx build map-aabb",
    "build:electron": "tsc -p electron/tsconfig.json",
    "watch:electron": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput",
    "start:electron": "wait-on tcp:4200 file:dist/electron/main.js && cross-env ELECTRON_RENDERER_URL=http://localhost:4200 electron .",
    "dev:electron": "concurrently -k -n WEB,ELECTRON_TS,ELECTRON -c cyan,yellow,green \"npm:dev:web\" \"npm:watch:electron\" \"npm:start:electron\"",
    "bundle:electron": "electron-builder",
    "package:electron": "run-s build:web build:electron bundle:electron"
  },
  "private": true,
  "dependencies": {
    "@types/maplibre-gl": "^1.14.0",
    "@types/three": "^0.183.1",
    "emf-converter": "^1.1.1",
    "maplibre-gl": "^4.7.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "0.174.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/playwright": "22.5.4",
    "@nx/react": "22.5.4",
    "@nx/vite": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "mammoth": "^1.12.0",
    "npm-run-all": "^4.1.5",
    "nx": "22.5.4",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.maplibre.threeaabb",
    "productName": "MaplibreThreeAabb",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/electron/**/*",
      "dist/map-aabb/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/electron/main.js"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    }
  },
  "nx": {
    "includedScripts": []
  }
}
